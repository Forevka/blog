            {
              "$type": "BlockGridLayoutItem",
              "columnSpan": 3,
              "rowSpan": 1,
              "areas": [],
              "contentUdi": null,
              "settingsUdi": null,
              "contentKey": "da98fe6c-65ef-4636-abfb-425402d04db8",
              "settingsKey": "d1b91f1f-ae6c-49c4-ae4e-e11e928626e4"
